# ── Application ────────────────────────────────  
APP_SECRET_KEY=your-very-secret-key-here  
APP_ENV=development  
FRONTEND_URL=http://localhost:3000  

# ── Database ─────────────────────────────────────  
DATABASE_URL=mongodb+srv://<user>:<pass>@cluster.mongodb.net/goavo  

# ── Clerk Authentication ──────────────────────────  
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx  
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx  
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in  
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up  
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard  
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard  
CLERK_SESSION_DURATION_HOURS=24  

# ── Email ────────────────────────────────────────  
EMAIL_PROVIDER=resend              # resend | smtp  
RESEND_API_KEY=re_xxxxxxxxxxxx  
SMTP_HOST=smtp.example.com  
SMTP_PORT=587  
SMTP_USER=you@example.com  
SMTP_PASSWORD=your-smtp-password  
FROM_EMAIL=noreply@goavo.ai  

# ── Encryption (for HubSpot key at rest) ─────────  
ENCRYPTION_KEY=32-byte-base64-encoded-key  

# ── HubSpot (Extension A) ────────────────────────  
HUBSPOT_DEFAULT_API_KEY=          # optional  
